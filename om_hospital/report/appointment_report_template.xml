<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- =====================================================================
         QWEB REPORT TEMPLATE — Hospital Appointment
         Renders a professional PDF with patient, doctor, date, and notes.
    ====================================================================== -->
    <template id="report_appointment_template">
        <t t-foreach="docs" t-as="o">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">

                    <div class="page">

                        <!-- ─── Report Header ─────────────────────────── -->
                        <div class="hospital-report-header text-center mb-4">
                            <h2 class="hospital-report-title">
                                Hospital Appointment Report
                            </h2>
                            <p class="text-muted">
                                Reference: <strong><t t-esc="o.name"/></strong>
                            </p>
                        </div>

                        <hr/>

                        <!-- ─── Appointment Details Table ─────────────── -->
                        <table class="table table-bordered hospital-report-table">
                            <thead class="hospital-report-thead">
                                <tr>
                                    <th colspan="2" class="text-center">
                                        Appointment Details
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="hospital-label"><strong>Patient Name</strong></td>
                                    <td><t t-esc="o.patient_id.name"/></td>
                                </tr>
                                <tr>
                                    <td class="hospital-label"><strong>Doctor</strong></td>
                                    <td>
                                        <t t-esc="o.doctor_id.name"/>
                                        <t t-if="o.doctor_id.specialization">
                                            —
                                            <em><t t-esc="o.doctor_id.specialization"/></em>
                                        </t>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="hospital-label"><strong>Appointment Date</strong></td>
                                    <td>
                                        <t t-esc="o.appointment_date"
                                           t-options="{'widget': 'datetime'}"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="hospital-label"><strong>Status</strong></td>
                                    <td>
                                        <t t-if="o.state == 'draft'">
                                            <span class="badge hospital-badge-draft">Draft</span>
                                        </t>
                                        <t t-elif="o.state == 'in_progress'">
                                            <span class="badge hospital-badge-inprogress">In Progress</span>
                                        </t>
                                        <t t-elif="o.state == 'done'">
                                            <span class="badge hospital-badge-done">Done</span>
                                        </t>
                                        <t t-elif="o.state == 'cancelled'">
                                            <span class="badge hospital-badge-cancelled">Cancelled</span>
                                        </t>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- ─── Description / Notes ───────────────────── -->
                        <t t-if="o.description">
                            <div class="hospital-notes-section mt-4">
                                <h5>Notes / Description</h5>
                                <div class="hospital-notes-box p-3 border rounded">
                                    <t t-esc="o.description"/>
                                </div>
                            </div>
                        </t>

                        <!-- ─── Footer ────────────────────────────────── -->
                        <div class="hospital-report-footer mt-5 text-center text-muted">
                            <small>
                                Generated by Hospital Management System &bull;
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %B %Y')"/>
                            </small>
                        </div>

                    </div><!-- .page -->

                </t><!-- web.external_layout -->
            </t><!-- web.html_container -->
        </t>
    </template>

</odoo>
